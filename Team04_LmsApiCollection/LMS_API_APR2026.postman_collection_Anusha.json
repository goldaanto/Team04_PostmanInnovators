            {
              "name": "getUserswithRole",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// Status check\r",
                      "pm.test(\"Status code is 200\", function () {\r",
                      "    pm.response.to.have.status(200);\r",
                      "});\r",
                      "\r",
                      "// Get response\r",
                      "let data = pm.response.json();\r",
                      "\r",
                      "// // Basic validations\r",
                      "// pm.test(\"Response is array\", function () {\r",
                      "//     pm.expect(data).to.be.an(\"array\");\r",
                      "// });\r",
                      "\r",
                      "pm.test(\"Users exist\", function () {\r",
                      "    pm.expect(data.length).to.be.above(0);\r",
                      "});\r",
                      "\r",
                      "// Role validation\r",
                      "pm.test(\"Valid roleIds\", function () {\r",
                      "    data.forEach(user => {\r",
                      "        pm.expect([\"R01\", \"R02\", \"R03\"]).to.include(user.roleId);\r",
                      "    });\r",
                      "});\r",
                      "\r",
                      "// Schema validation\r",
                      "pm.test(\"Schema is valid\", function () {\r",
                      "    const schema = {\r",
                      "        type: \"array\",\r",
                      "        items: {\r",
                      "            type: \"object\",\r",
                      "            required: [\r",
                      "                \"roleId\",\r",
                      "                \"roleName\",\r",
                      "                \"userId\",\r",
                      "                \"userFirstName\",\r",
                      "                \"userLastName\",\r",
                      "                \"userRoleStatus\",\r",
                      "                \"userLocation\",\r",
                      "                \"userTimeZone\",\r",
                      "                \"userVisaStatus\",\r",
                      "                \"userLoginEmail\"\r",
                      "            ],\r",
                      "            properties: {\r",
                      "                roleId: { type: \"string\" },\r",
                      "                roleName: { type: \"string\" },\r",
                      "                userId: { type: \"string\" },\r",
                      "                userFirstName: { type: \"string\" },\r",
                      "                userLastName: { type: \"string\" },\r",
                      "                userRoleStatus: { type: \"string\" },\r",
                      "                userLocation: { type: \"string\" },\r",
                      "                userTimeZone: { type: \"string\" },\r",
                      "                userVisaStatus: { type: \"string\" },\r",
                      "                userLoginEmail: { type: \"string\" }\r",
                      "            }\r",
                      "        }\r",
                      "    };\r",
                      "\r",
                      "    pm.expect(data).to.have.jsonSchema(schema);\r",
                      "});\r",
                      "\r",
                      "// Debug log\r",
                      "console.log(\"Users with Roles:\", data);"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
